{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Requêtes HTTP / sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"employees-api\"}[1m])",
          "legendFormat": "{{method}} {{uri}}"
        }
      ]
    },
    {
      "title": "Latence moyenne (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_sum{application=\"employees-api\"}[1m]) / rate(http_server_requests_seconds_count{application=\"employees-api\"}[1m])",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "title": "Mémoire JVM utilisée (MB)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"employees-api\", area=\"heap\"} / 1024 / 1024",
          "legendFormat": "{{id}}"
        }
      ]
    },
    {
      "title": "Statut backend (UP=1)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "up{job=\"employees-api\"}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "title": "Employees API — Monitoring",
  "uid": "employees-api",
  "version": 1
}
