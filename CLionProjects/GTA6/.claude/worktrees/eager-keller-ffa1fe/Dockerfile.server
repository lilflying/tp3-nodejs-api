# ── Serveur dedie GTA VI (headless, sans rendu) ──────────────────────────────
# Construit raylib puis compile le serveur autoritaire. Ne calcule QUE la
# simulation + le reseau (aucune fenetre / GPU requis a l'execution).
#
#   docker build -f Dockerfile.server -t gta6-server .
#   docker run --rm -p 7777:7777 gta6-server
#
# Le conteneur ecoute en TCP sur 7777. Combine-le avec un tunnel (Tailscale /
# ngrok) ou deploie-le sur un VPS a IP publique pour jouer a distance.

# ---- build ----
FROM ubuntu:24.04 AS build
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake git ca-certificates \
    libgl1-mesa-dev libx11-dev libxrandr-dev libxinerama-dev \
    libxcursor-dev libxi-dev && rm -rf /var/lib/apt/lists/*
# raylib 5.5
RUN git clone --depth 1 --branch 5.5 https://github.com/raysan5/raylib.git /raylib \
 && cmake -S /raylib -B /raylib/build -DBUILD_EXAMPLES=OFF -DCMAKE_BUILD_TYPE=Release \
 && cmake --build /raylib/build -j --target install
COPY gta6_3d.cpp /src/gta6_3d.cpp
RUN g++ -std=c++17 -O2 /src/gta6_3d.cpp -o /gta6_server \
    -lraylib -lGL -lm -lpthread -ldl -lrt -lX11

# ---- runtime ----
FROM ubuntu:24.04
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libx11-6 libxrandr2 libxinerama1 libxcursor1 libxi6 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=build /gta6_server /usr/local/bin/gta6_server
COPY --from=build /usr/local/lib/libraylib* /usr/local/lib/
RUN ldconfig
EXPOSE 7777
ENTRYPOINT ["gta6_server", "--server", "--port", "7777"]
